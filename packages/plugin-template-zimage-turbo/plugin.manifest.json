{
  "id": "demo.zimage_turbo.image_provider",
  "name": "Z-Image Turbo Demo Provider",
  "version": "0.1.0",
  "author": "Muse Team",
  "description": "Reference extension plugin template for image.generate using a Z-Image Turbo style adapter.",
  "museApiVersion": "1",
  "service": {
    "baseUrl": "http://127.0.0.1:18181",
    "healthPath": "/health",
    "authScheme": "none"
  },
  "permissions": [
    "media:generate"
  ],
  "hooks": [
    {
      "capability": "image.generate",
      "method": "POST",
      "path": "/hooks/image.generate"
    }
  ]
}

