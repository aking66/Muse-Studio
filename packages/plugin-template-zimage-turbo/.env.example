# Copy to `.env` in this folder (next to `config.json`).
# Loaded automatically on startup by `load_plugin_dotenv()` in `app/config_loader.py`.
#
# Priority for model path: `ZIMAGE_MODEL_DIR` (env / this file) wins over `config.json` `model_root`.

# Optional: override `config.json` model root (HF layout folder)
# ZIMAGE_MODEL_DIR=F:/models/zimage-turbo

# PLUGIN_OUTPUTS_DIR=./outputs
# Optional HTTP base if you serve ./outputs behind a static host (else finalImage.url uses file://)
# PLUGIN_PUBLIC_BASE_URL=http://127.0.0.1:8080

# MCP (`python -m app.mcp_server`)
# ZIMAGE_MCP_TRANSPORT=stdio
# ZIMAGE_MCP_TRANSPORT=streamable-http
# ZIMAGE_MCP_HOST=127.0.0.1
# ZIMAGE_MCP_PORT=18182
# ZIMAGE_MODEL_DIR=F:/models/zimage-turbo
