# Copy to `.env` in this folder (same directory as server.mjs).
# Loaded automatically on startup via dotenv.

# Write tools (generateScenes, ingestScene, orchestrate, videoEditor, applyFilmTimeline)
MCP_ALLOW_WRITE=True

MCP_PORT=3333
MCP_BIND_HOST=127.0.0.1
MUSE_STUDIO_BASE_URL=http://127.0.0.1:3000
# MUSE_STUDIO_DB_PATH=E:\path\to\muse-studio\db\muse.db

# Optional: Bearer token for remote clients
# MCP_AUTH_TOKEN=

# Optional: comma-separated allowlists
# MCP_ALLOWED_TOOLS=listProjects,getProject
# MCP_ALLOWED_PROJECT_IDS=proj-abc123
