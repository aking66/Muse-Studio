{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "sd_xl_turbo_1.0_fp16.safetensors"
    },
    "_meta": {
      "title": "Load Checkpoint"
    }
  },
  "8": {
    "class_type": "LoraLoader",
    "inputs": {
      "lora_name": "ScribbleStyle_XL.safetensors",
      "strength_model": 0.8,
      "strength_clip": 0.8,
      "model": ["1", 0],
      "clip": ["1", 1]
    },
    "_meta": {
      "title": "ScribbleStyle LoRA"
    }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "scribble style, black and white sketch",
      "clip": ["8", 1]
    },
    "_meta": {
      "title": "Prompt (Input)"
    }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "color, photorealistic, 3d render, blurry, deformed",
      "clip": ["8", 1]
    },
    "_meta": {
      "title": "Negative Prompt"
    }
  },
  "3": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": 1024,
      "height": 1024,
      "batch_size": 1
    },
    "_meta": {
      "title": "Image Size"
    }
  },
  "4": {
    "class_type": "KSampler",
    "inputs": {
      "seed": 42,
      "control_after_generate": "randomize",
      "steps": 4,
      "cfg": 1.5,
      "sampler_name": "euler_ancestral",
      "scheduler": "simple",
      "denoise": 1.0,
      "model": ["8", 0],
      "positive": ["2", 0],
      "negative": ["6", 0],
      "latent_image": ["3", 0]
    },
    "_meta": {
      "title": "KSampler"
    }
  },
  "5": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["4", 0],
      "vae": ["1", 2]
    },
    "_meta": {
      "title": "VAE Decode"
    }
  },
  "7": {
    "class_type": "SaveImage",
    "inputs": {
      "filename_prefix": "scribble",
      "images": ["5", 0]
    },
    "_meta": {
      "title": "Save Image (Output)"
    }
  }
}
